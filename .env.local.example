
# Chave do seu workspace Lovable (Settings ▸ Members ▸ API Keys)
VITE_LOVABLE_API_KEY=sk-workspace_xxxxxxxxxxxxxxxxxxxxxxxxx

# URL do servidor MCP (Local)
VITE_MCP_URL=http://localhost:8080

# URL do servidor MCP (Railway - substitua pela sua URL)
# VITE_MCP_URL=https://seu-mcp-server.up.railway.app

# Modelo default para o MCP
VITE_LOVABLE_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Configurações MCP (se usar autenticação)
VITE_MCP_HEADER=api-key
VITE_MCP_TOKEN=local-dev

# Railway Environment (automaticamente definido pelo Railway)
# RAILWAY_ENVIRONMENT=production
